# Required for paid OpenRouter video generation
OPENROUTER_API_KEY=

# Optional OpenRouter metadata
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Text to Image and Video Generator

# Optional Pollinations settings. Flux is the default because GPT image models
# can show the public "too many requests / request queued" message quickly.
# Get a token at https://auth.pollinations.ai if you want higher limits.
POLLINATIONS_MODEL=flux
POLLINATIONS_FALLBACK_MODELS=turbo,gpt-image-large
POLLINATIONS_TOKEN=

# Vision gate backend. Default uses local Hermes Agent CLI with whatever
# vision-capable provider/model Hermes is configured to use.
VIDEO_ORCHESTRATOR_REVIEWER=hermes
HERMES_COMMAND=hermes

# Review subprocess provider/model. Defaults target OpenRouter using OPENROUTER_API_KEY.
HERMES_REVIEW_PROVIDER=openrouter
HERMES_REVIEW_MODEL=openai/gpt-4o-mini

# Prompt rewrite subprocess provider/model. Used by the "Rewrite prompt" buttons.
PROMPT_REWRITE_PROVIDER=openrouter
PROMPT_REWRITE_MODEL=openai/gpt-4o-mini
PROMPT_REWRITE_TIMEOUT=30

# Optional: use Hermes Agent for text-only prompt optimization too.
# Default "local" uses the built-in deterministic prompt expander.
VIDEO_ORCHESTRATOR_PROMPT_OPTIMIZER=local

# Optional: when true, block video generation if the selected visual reviewer is unavailable.
VIDEO_ORCHESTRATOR_REQUIRE_VISION=true

# Default soft review mode avoids blocking I2V for low-confidence nitpicks,
# unreadable Hermes JSON, nonzero Hermes exits, or timeout/provider hiccups.
# Set strict mode true to restore block-on-any-review-failure behavior.
VIDEO_ORCHESTRATOR_SOFT_REVIEW_FAILURES=true
VIDEO_ORCHESTRATOR_REJECTION_CONFIDENCE_THRESHOLD=0.85
VIDEO_ORCHESTRATOR_STRICT_REVIEW=false

# Hermes review can be slower than Railway/browser request budgets.
# Raise this for stricter review, or enable timeout fallback to generate anyway
# if the free storyboard image passed basic structural checks.
HERMES_REVIEW_TIMEOUT=30
VIDEO_ORCHESTRATOR_ALLOW_REVIEW_TIMEOUT=true
