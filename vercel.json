{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "buildCommand": "pip install -r requirements.txt && echo '=== DEPLOYED FILES ===' && find . -name '*.css' -o -name '*.js' -o -name '*.png' -o -name '*.jpg' | head -20"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ],
  "includeFiles": ["static/**"],
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-jobs",
      "schedule": "0 3 * * *"
    }
  ]
}